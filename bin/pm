#!/usr/bin/env ruby
require "base64"
@passwords = {}

PASSWORDS_FILE="/Users/ayushpai/.config/pm/passwords.txt"
LOGIN_USERNAME_FILE="/Users/ayushpai/.config/pm/login/username.txt"
LOGIN_PASSWORD_FILE="/Users/ayushpai/.config/pm/login/password.txt"

def encrypt(text)
  Base64.strict_encode64(text)
end

def decrypt(text)
  return nil if text.nil? || text.empty?
  Base64.strict_decode64(text)
end

def get_username()
  file = File.open(LOGIN_USERNAME_FILE, "r")
    Base64.decode64(file.read())
end

def get_password()
  file = File.open(LOGIN_PASSWORD_FILE, "r")
    Base64.decode64(file.read())
end

def read_from_file
  return unless File.exist?(PASSWORDS_FILE)

  File.open(PASSWORDS_FILE, "r") do |file|
    file.each_line do |line|
      line = line.strip

      next if line.empty?

      unless line.include?("/")
        next
      end

      app, encrypted_password = line.split("/", 2)

      if encrypted_password.nil? || encrypted_password.empty?
        next
      end

      begin
        decrypted_password = decrypt(encrypted_password)
        @passwords[app] = decrypted_password

      rescue ArgumentError
      end
    end
  end
end

def write_to_file(app_name, password)
  File.open(PASSWORDS_FILE, "a") do |file|
    encrypted_password = encrypt(password)
    file.puts("#{app_name}/#{encrypted_password}")
  end
end

def run()
    print "Type the name of an app "
    ask = gets.chomp

    ask = ask.strip()

    if @passwords.key?(ask)
        puts "The password of #{ask} is #{@passwords[ask]}"

    else
        print "What is the password of #{ask} "
        add_1 = gets.chomp

        add_1 = add_1.strip()

        @passwords[ask] = add_1
        write_to_file(ask, add_1)

        puts "Password saved successfully"
    end

    after(100, run)
end

def ask_question()
  print "Enter username "
  username = gets.chomp

  if username == get_username()

      print "Enter password "
      password = gets.chomp

      if password == get_password()
          run()

      else
          puts "Unauthorized access"
      end

  else
      puts "Unauthorized access"
  end
end

read_from_file()
ask_question()
