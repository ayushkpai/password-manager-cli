#!/usr/bin/env ruby
require "dotenv"
require "base64"

possible_paths = [
  File.expand_path("~/src/ruby/ruby/.password-manager-cli/.env", Dir.pwd),
  File.join(Dir.pwd, ".env")
]

env_file = possible_paths.find { |f| File.exist?(f) }

unless File.exist?(env_file)
  abort("Missing .env file in current directory")
end

Dotenv.load(env_file)

required = %w[PASSWORDS_FILE USERNAME_FILE PASSWORD_FILE]

missing = required.select { |k| ENV[k].to_s.strip.empty? }

unless missing.empty?
  abort("Missing environment variables: #{missing.join(', ')}")
end

PASSWORDS_FILE = ENV["PASSWORDS_FILE"]
LOGIN_USERNAME_FILE = ENV["USERNAME_FILE"]
LOGIN_PASSWORD_FILE = ENV["PASSWORD_FILE"]

@passwords = {}

def encrypt(text)
  Base64.strict_encode64(text)
end

def decrypt(text)
  return nil if text.nil? || text.empty?
  Base64.strict_decode64(text)
end

def get_username
  return nil unless File.exist?(LOGIN_USERNAME_FILE)
  File.read(LOGIN_USERNAME_FILE).strip
end

def get_password
  return nil unless File.exist?(LOGIN_PASSWORD_FILE)
  Base64.decode64(File.read(LOGIN_PASSWORD_FILE)).strip
end


def read_from_file
  return unless File.exist?(PASSWORDS_FILE)

  File.foreach(PASSWORDS_FILE) do |line|
    line = line.strip
    next if line.empty?
    next unless line.include?("/")

    app, encrypted_password = line.split("/", 2)
    next if encrypted_password.nil? || encrypted_password.empty?

    begin
      @passwords[app] = decrypt(encrypted_password)
    rescue ArgumentError
      next
    end
  end
end

def write_to_file(app_name, password)
  File.open(PASSWORDS_FILE, "a") do |file|
    file.puts("#{app_name}/#{encrypt(password)}")
  end
end

def run
  loop do
    print "Type app name (or Ctrl+C to exit): "
    app = gets&.chomp&.strip
    break if app.nil? || app.empty?

    if @passwords.key?(app)
      puts "Password for #{app}: #{@passwords[app]}"
    else
      print "Set password for #{app}: "
      pass = gets&.chomp&.strip
      next if pass.nil? || pass.empty?

      @passwords[app] = pass
      write_to_file(app, pass)

      puts "Password saved successfully"
    end
  end
end

def ask_question
  print "Enter username: "
  username = gets&.chomp&.strip

  if username == get_username
    print "Enter password: "
    password = gets&.chomp&.strip

    if password == get_password
      read_from_file
      run
    else
      puts "Unauthorized access"
    end
  else
    puts "Unauthorized access"
  end
end

begin
  ask_question
rescue Interrupt
  puts "\nExiting..."
end
