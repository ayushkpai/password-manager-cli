#!/usr/bin/env ruby

require "dotenv"
require "openssl"
require "json"
require "base64"
require "securerandom"
require "io/console"
require "fileutils"

CONFIG_DIR = File.join(Dir.home, ".config", "pm")
ENV_FILE = File.join(CONFIG_DIR, ".env")

Dotenv.load(ENV_FILE)

VAULT_FILE = ENV["VAULT_FILE"]
ITERATIONS = (ENV["ITERATIONS"] || 600_000).to_i
KEY_LEN = 32

abort <<~MSG if VAULT_FILE.nil? || VAULT_FILE.empty?
Missing configuration.

Create:

  #{ENV_FILE}

Example:

  VAULT_FILE=#{CONFIG_DIR}/config.json
  ITERATIONS=600000
MSG

FileUtils.mkdir_p(File.dirname(VAULT_FILE))

def load_vault
  return nil unless File.exist?(VAULT_FILE)

  vault = JSON.parse(File.read(VAULT_FILE))
  vault["passwords"] ||= {}
end

def save_vault(vault)
  File.write(VAULT_FILE, JSON.pretty_generate(vault))
  File.chmod(0600, VAULT_FILE)
end

def derive_key(password, salt)
  OpenSSL::PKCS5.pbkdf2_hmac(
    password,
    salt,
    ITERATIONS,
    KEY_LEN,
    "sha256"
  )
end

def encrypt(text, key)
  cipher = OpenSSL::Cipher.new("aes-256-gcm")
  cipher.encrypt

  iv = SecureRandom.random_bytes(12)
  cipher.key = key
  cipher.iv = iv

  ciphertext = cipher.update(text) + cipher.final
  tag = cipher.auth_tag

  {
    "iv" => Base64.strict_encode64(iv),
    "tag" => Base64.strict_encode64(tag),
    "data" => Base64.strict_encode64(ciphertext)
  }
end

def decrypt(enc, key)
  cipher = OpenSSL::Cipher.new("aes-256-gcm")
  cipher.decrypt

  cipher.key = key
  cipher.iv = Base64.strict_decode64(enc["iv"])
  cipher.auth_tag = Base64.strict_decode64(enc["tag"])

  data = Base64.strict_decode64(enc["data"])

  cipher.update(data) + cipher.final
rescue
  nil
end

def prompt_hidden(msg)
  print msg
  STDIN.noecho(&:gets).chomp.tap { puts }
end

def create_account
  return load_vault if File.exist?(VAULT_FILE)

  pass1 = prompt_hidden("Create master password: ")
  pass2 = prompt_hidden("Confirm master password: ")

  if pass1 != pass2
    puts "Passwords do not match"
    exit
  end

  salt = SecureRandom.random_bytes(16)
  key = derive_key(pass1, salt)

  vault = {
    "version": 1,
    "salt" => Base64.strict_encode64(salt),
    "verify" => encrypt("ok", key),
    "passwords" => {}
  }

  save_vault(vault)
  puts "Account created"

  vault
end

def authenticate
  vault = load_vault

  if vault.nil? || !vault.is_a?(Hash) || !vault["salt"]
    vault = create_account
  end

  vault["passwords"] ||= {}   # ✅ ADD THIS HERE

  password = prompt_hidden("Master password: ")

  salt = Base64.strict_decode64(vault["salt"])
  key = derive_key(password, salt)

  unless vault["verify"] && decrypt(vault["verify"], key) == "ok"
    puts "Wrong master password"
    return nil
  end

  [vault, key]
end

def list(vault)
  puts "\nSaved entries:"
  vault["passwords"].each_key { |k| puts "- #{k}" }
end

def add(vault, key)
  print "Service name: "
  name = gets&.chomp
  return if name.to_s.empty?

  pass = prompt_hidden("Password: ")

  vault["passwords"][name] = encrypt(pass, key)
  save_vault(vault)

  puts "Saved"
end

def view(vault, key)
  print "Service name: "
  name = gets&.chomp

  data = vault["passwords"][name]
  return puts "Not found" unless data

  pass = decrypt(data, key)
  puts pass ? "Password: #{pass}" : "Decryption failed"
end

def delete_entry(vault)
  print "Service name: "
  name = gets&.chomp

  if vault["passwords"].delete(name)
    save_vault(vault)
    puts "Deleted"
  else
    puts "Not found"
  end
end

def change_master(vault, key)
  old_key = key

  unless decrypt(vault["verify"], old_key) == "ok"
    puts "Wrong password"
    return key
  end

  new1 = prompt_hidden("New master password: ")
  new2 = prompt_hidden("Confirm new password: ")
  return key if new1 != new2

  new_salt = SecureRandom.random_bytes(16)
  new_key = derive_key(new1, new_salt)

  new_passwords = {}

  vault["passwords"].each do |k, v|
    plain = decrypt(v, old_key)
    next if plain.nil?
    new_passwords[k] = encrypt(plain, new_key)
  end

  vault["salt"] = Base64.strict_encode64(new_salt)
  vault["verify"] = encrypt("ok", new_key)
  vault["passwords"] = new_passwords

  save_vault(vault)

  puts "Master password updated"

  new_key   # ⭐ IMPORTANT
end

def delete_account
  confirm = prompt_hidden("Type DELETE to remove account: ")

  if confirm == "DELETE"
    File.delete(VAULT_FILE) if File.exist?(VAULT_FILE)
    puts "Account deleted"
    exit
  else
    puts "Cancelled"
  end
end

def menu(vault, key)
  loop do
    puts "\n1. List"
    puts "2. Add"
    puts "3. View"
    puts "4. Delete entry"
    puts "5. Change master password"
    puts "6. Delete account"
    puts "7. Exit"

    print "Choice: "
    c = gets&.chomp

    case c
    when "1" then list(vault)
    when "2" then add(vault, key)
    when "3" then view(vault, key)
    when "4" then delete_entry(vault)
    when "5"
      key = change_master(vault, key)
    when "6" then delete_account
    when "7" then break
    else puts "Invalid"
    end
  end
end

begin
  result = authenticate
  exit unless result

  vault, key = result
  menu(vault, key)
rescue Interrupt
end
