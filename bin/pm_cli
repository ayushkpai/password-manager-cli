#!/usr/bin/env ruby

require "dotenv"
require "openssl"
require "json"
require "base64"
require "securerandom"
require "io/console"
require "fileutils"

CONFIG_DIR = File.join(Dir.home, ".config", "pm")
ENV_FILE = File.join(CONFIG_DIR, ".env")
Dotenv.load(ENV_FILE)

VAULT_FILE = ENV["VAULT_FILE"]
ITERATIONS = (ENV["ITERATIONS"] || "600000").to_i
KEY_LEN = 32

abort "Missing VAULT_FILE in env" if VAULT_FILE.nil? || VAULT_FILE.empty?

FileUtils.mkdir_p(File.dirname(VAULT_FILE))

def b64e(x)
  Base64.strict_encode64(x)
end

def b64d(x)
  Base64.strict_decode64(x.to_s.strip)
end

def load_vault
  return nil unless File.exist?(VAULT_FILE)
  v = JSON.parse(File.read(VAULT_FILE)) rescue nil
  return nil unless v
  v["passwords"] ||= {}
  v
end

def save_vault(v)
  File.write(VAULT_FILE, JSON.pretty_generate(v))
  File.chmod(0600, VAULT_FILE)
end

def derive_key(password, salt)
  OpenSSL::PKCS5.pbkdf2_hmac(password, salt, ITERATIONS, KEY_LEN, "sha256")
end

def encrypt(text, key)
  cipher = OpenSSL::Cipher.new("aes-256-gcm")
  cipher.encrypt

  iv = SecureRandom.random_bytes(12)
  cipher.key = key
  cipher.iv = iv

  ct = cipher.update(text) + cipher.final
  tag = cipher.auth_tag

  {
    "iv" => b64e(iv),
    "tag" => b64e(tag),
    "data" => b64e(ct)
  }
end

def decrypt(enc, key)
  cipher = OpenSSL::Cipher.new("aes-256-gcm")
  cipher.decrypt

  cipher.key = key
  cipher.iv = b64d(enc["iv"])
  cipher.auth_tag = b64d(enc["tag"])

  data = b64d(enc["data"])

  (cipher.update(data) + cipher.final).force_encoding("UTF-8")
rescue
  nil
end

def prompt(msg)
  print msg
  STDIN.noecho(&:gets).chomp.tap { puts }
end

def create_account
  return load_vault if File.exist?(VAULT_FILE)

  p1 = prompt("Create master password: ")
  p2 = prompt("Confirm master password: ")
  return unless p1 == p2

  salt = SecureRandom.random_bytes(16)
  key = derive_key(p1, salt)

  v = {
    "salt" => b64e(salt),
    "verify" => encrypt("ok", key),
    "passwords" => {}
  }

  save_vault(v)
  v
end

def authenticate
  v = load_vault
  v = create_account if v.nil?

  pass = prompt("Master password: ")
  salt = b64d(v["salt"])
  key = derive_key(pass, salt)

  return nil unless decrypt(v["verify"], key) == "ok"

  [v, key]
end

def list(v)
  puts "\nSaved services:"
  v["passwords"].each_key { |k| puts "- #{k}" }
end

def add(v, key)
  print "Service: "
  name = gets.chomp
  print "Password: "
  pass = gets.chomp

  v["passwords"][name] = encrypt(pass, key)
  save_vault(v)
end

def view(v, key)
  print "Service: "
  name = gets.chomp
  enc = v["passwords"][name]
  return puts "Not found" unless enc

  puts decrypt(enc, key)
end

def delete(v)
  print "Service: "
  name = gets.chomp
  v["passwords"].delete(name)
  save_vault(v)
end

def menu(v, key)
  loop do
    puts "\n1 List  2 Add  3 View  4 Delete  5 Exit"
    case gets.chomp
    when "1" then list(v)
    when "2" then add(v, key)
    when "3" then view(v, key)
    when "4" then delete(v)
    when "5" then break
    end
  end
end

begin
  res = authenticate
  exit unless res
  v, key = res
  menu(v, key)
rescue Interrupt
  puts "\nExit"
end
