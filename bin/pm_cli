#!/usr/bin/env ruby

require "json"
require "base64"
require "openssl"
require "securerandom"
require "io/console"
require "fileutils"

APP = "pm"
DIR = File.join(Dir.home, ".config", APP)
FILE = File.join(DIR, "cli.json")

FileUtils.mkdir_p(DIR)
FileUtils.chmod(0700, DIR)

def b64e(x)
  Base64.strict_encode64(x)
end

def b64d(x)
  Base64.strict_decode64(x.to_s)
end

def prompt(msg)
  print msg
  gets&.chomp.to_s
end

def secret(msg)
  print msg
  STDIN.noecho(&:gets).to_s.chomp.tap { puts }
end

def key_from(pass, salt)
  OpenSSL::PKCS5.pbkdf2_hmac(pass, salt, 200_000, 32, "sha256")
end

def enc(data, key)
  c = OpenSSL::Cipher.new("aes-256-gcm")
  c.encrypt
  iv = SecureRandom.random_bytes(12)
  c.key = key
  c.iv = iv

  ct = c.update(data) + c.final

  {
    "iv" => b64e(iv),
    "tag" => b64e(c.auth_tag),
    "data" => b64e(ct)
  }
end

def dec(obj, key)
  return nil unless obj.is_a?(Hash)

  c = OpenSSL::Cipher.new("aes-256-gcm")
  c.decrypt
  c.key = key
  c.iv = b64d(obj["iv"])
  c.auth_tag = b64d(obj["tag"])

  (c.update(b64d(obj["data"])) + c.final).force_encoding("UTF-8")
rescue
  nil
end

def load_vault
  return nil unless File.exist?(FILE)
  v = JSON.parse(File.read(FILE))
  v if v.is_a?(Hash)
rescue
  nil
end

def save_vault(v)
  tmp = FILE + ".tmp"
  File.write(tmp, JSON.pretty_generate(v))
  File.rename(tmp, FILE)
  File.chmod(0600, FILE)
end

def init_vault
  return load_vault if File.exist?(FILE)

  p1 = secret("Create master password: ")
  p2 = secret("Confirm password: ")
  abort "Mismatch" if p1 != p2 || p1.empty?

  salt = SecureRandom.random_bytes(16)
  key = key_from(p1, salt)

  vault = {
    "salt" => b64e(salt),
    "verify" => enc("ok", key),
    "data" => {}
  }

  save_vault(vault)
  vault
end

def auth
  v = load_vault
  v = init_vault unless v && v["salt"] && v["verify"] && v["data"].is_a?(Hash)

  pass = secret("Master password: ")
  salt = b64d(v["salt"])
  key = key_from(pass, salt)

  ok = dec(v["verify"], key)
  abort "Invalid password" unless ok == "ok"

  [v, key]
end

def gen(len = 20)
  chars = (("a".."z").to_a + ("A".."Z").to_a + ("0".."9").to_a + %w[! @ # $ % ^ & * _ + - = ?])
  Array.new(len.to_i) { chars.sample }.join
end

def copy(text)
  return unless RbConfig::CONFIG["host_os"] =~ /darwin/
  IO.popen("pbcopy", "w") { |io| io.write(text) }
end

def add(v, key, name)
  pass = secret("Password (blank = generate): ")
  pass = gen if pass.empty?

  v["data"][name] = enc(JSON.dump({ "p" => pass }), key)
  save_vault(v)
  puts "Saved"
end

def get(v, key, name)
  e = v["data"][name]
  return puts "Not found" unless e

  d = JSON.parse(dec(e, key) || "{}")
  puts "Pass: #{d["p"]}"
end

def list(v)
  v["data"].keys.each { |k| puts k }
end

def delete(v, name)
  v["data"].delete(name)
  save_vault(v)
  puts "Deleted"
end

def copy_cmd(v, key, name)
  e = v["data"][name]
  return puts "Not found" unless e

  d = JSON.parse(dec(e, key) || "{}")
  copy(d["p"])
  puts "Copied"
end

def help
  puts <<~TXT
    Commands:
      add <name>
      get <name>
      list
      delete <name>
      copy <name>
      gen [len]
  TXT
end

v, k = auth
cmd = ARGV.shift

case cmd
when "add" then add(v, k, ARGV.shift)
when "get" then get(v, k, ARGV.shift)
when "list" then list(v)
when "delete" then delete(v, ARGV.shift)
when "copy" then copy_cmd(v, k, ARGV.shift)
when "gen" then puts gen(ARGV.shift || 20)
else help
end
